# ─────────────────────────────────────────────────────────────────
#  Job Tracker AI — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── App / JWT ──────────────────────────────────────────────────────
# Signs JWT access/refresh tokens — set a long random value in production
SECRET_KEY=hired-dev-secret-change-before-deploy-xK9mP2vQ8nR4wL7j
# Public URL of this app (used to build OAuth-login redirect targets)
FRONTEND_URL=http://localhost:8080
# Comma-separated list of allowed CORS origins, or * for any
ALLOWED_ORIGINS=*

# ── Database ─────────────────────────────────────────────────────
DB_PATH=jobtracker.db

# ── AI provider ──────────────────────────────────────────────────
# Option A — xAI Grok (paid):  console.x.ai
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROK_MODEL=grok-3-mini
AI_BASE_URL=https://api.x.ai/v1

# Option B — Groq (free tier): console.groq.com
# XAI_API_KEY=gsk_your_groq_key_here
# GROK_MODEL=llama-3.3-70b-versatile
# AI_BASE_URL=https://api.groq.com/openai/v1

# ── Google OAuth (sign-in + Gmail scan) ────────────────────────────
# 1. Go to console.cloud.google.com → New project
# 2. APIs & Services → Enable APIs → search "Gmail API" → Enable
# 3. APIs & Services → Credentials → Create OAuth client ID → Web application
# 4. Add Authorised redirect URIs:
#      http://localhost:5001/auth/google/callback
#      http://localhost:5001/auth/google/login/callback
# 5. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Must exactly match the redirect URIs registered in Google Cloud Console
# Change these if you run on a different port or deploy publicly
REDIRECT_URI=http://localhost:5001/auth/google/callback
REDIRECT_URI_LOGIN=http://localhost:5001/auth/google/login/callback
